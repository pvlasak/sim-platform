# backend/.env

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=simflow

# Git — absolute path to your local git clone
# This folder must already exist (git clone done manually once)
# SSH key must be configured on your machine and added to GitLab
GIT_REPO_PATH=/work/proj/github/model-repository
GIT_BRANCH=main
GIT_USER_NAME=simflow
GIT_USER_EMAIL=simflow@example.com
